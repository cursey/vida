{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main desktop window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:menu:default",
    "core:path:default",
    "core:resources:default",
    "core:webview:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "allow-pick-executable",
    "allow-pick-pdb",
    "allow-add-recent-executable",
    "allow-get-window-chrome-state",
    "allow-window-control",
    "allow-get-title-bar-menu-model",
    "allow-invoke-title-bar-menu-action",
    "allow-ping-engine",
    "allow-get-module-pdb-status",
    "allow-open-module",
    "allow-unload-module",
    "allow-get-module-analysis-status",
    "allow-get-module-info",
    "allow-get-module-memory-overview",
    "allow-list-functions",
    "allow-get-function-graph-by-va",
    "allow-get-xrefs-to-va",
    "allow-disassemble-linear",
    "allow-get-linear-view-info",
    "allow-get-linear-rows",
    "allow-find-linear-row-by-va"
  ]
}
