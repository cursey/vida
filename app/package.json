{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "description": "Tauri UI for electron-disassembler",
  "license": "MIT",
  "scripts": {
    "build:renderer": "vite build",
    "build": "tauri build --debug --no-bundle",
    "dev": "npm run build:renderer && tauri dev",
    "lint": "biome lint .",
    "fmt": "biome check --write . && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "check": "npm run build:renderer && biome check . && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.renderer.json --noEmit && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check && cargo check --manifest-path src-tauri/Cargo.toml",
    "test:renderer": "vitest run",
    "test:backend": "npm run build:renderer && cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "node --test test/**/*.test.js && npm run test:renderer && npm run test:backend",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cytoscape": "^3.33.1",
    "cytoscape-node-html-label": "^1.2.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "autoprefixer": "^10.4.27",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.2",
    "vite": "^7.1.0",
    "vitest": "^4.0.18"
  }
}
