{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "V.ıDA Pro",
  "version": "0.1.0",
  "identifier": "com.electrondisassembler.vida-pro",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "V.ıDA Pro",
        "width": 1500,
        "height": 950,
        "minWidth": 1200,
        "minHeight": 720,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/engine"]
  }
}
